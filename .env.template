# costbench environment template.
#
# Copy this to `.env` (which is gitignored) and fill in what you need:
#   cp .env.template .env
#
# costbench auto-loads `.env` from the current directory on startup. Values
# already set in your shell ALWAYS win over the file, so an explicit `export`
# overrides `.env`. Secrets never belong in a config file or in git — `.env`
# is the one place they live, and it is ignored by version control.

# ── Provider API keys (only the ones whose models you actually run) ──────────
# Read by litellm when a `model` target calls out. Key names are litellm's.
# Match them to the providers shown in the costbench pricing table / Targets tree.
ANTHROPIC_API_KEY=          # anthropic/*   (Claude)
OPENAI_API_KEY=             # openai/*      (GPT)
GEMINI_API_KEY=             # gemini/*      (Google)
MISTRAL_API_KEY=            # mistral/*
DEEPSEEK_API_KEY=           # deepseek/*
DASHSCOPE_API_KEY=          # qwen/*        (Alibaba Model Studio / DashScope)
# local/* models are self-hosted (amortized GPU) and need no API key. Serve them
# through litellm as e.g. an ollama/ or OpenAI-compatible localhost endpoint.

# ── `costbench pull` — external case sources ────────────────────────────────
# A pull config names the env var holding its connection string via `dsn_env`.
# The example uses QUALITYMAX_DB_URL; use a READ-ONLY database role.
QUALITYMAX_DB_URL=          # postgresql://READONLY_USER:...@host:5432/postgres

# ── `endpoint` targets ──────────────────────────────────────────────────────
# An endpoint target reads its bearer token from the var named in `auth_env`.
# Add one line per endpoint you benchmark, e.g.:
# MY_API_KEY=

# ── Optional costbench knobs ────────────────────────────────────────────────
# COSTBENCH_JUDGE_MODEL=anthropic/claude-haiku-4-5   # LLM-as-judge for the semantic example
# COSTBENCH_HISTORY=                                  # path to the calibration history file
# COSTBENCH_FREE_TIER_MAX_CASES=                      # cap cases for an estimate quota (host seam)
